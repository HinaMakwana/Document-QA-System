# ============================================================
# Production Environment Variables (Render.com Deployment)
# ============================================================
# Copy this to .env on Render or set in Render Dashboard → Environment

# Django Settings
DEBUG=False
SECRET_KEY=<auto-generated-by-render>
ALLOWED_HOSTS=.onrender.com
ENVIRONMENT=production

# Database (auto-populated by Render if using Blueprint)
DATABASE_URL=<auto-populated-by-render>

# Redis (auto-populated by Render if using Blueprint)
REDIS_URL=<auto-populated-by-render>
CELERY_BROKER_URL=<auto-populated-by-render>

# Synchronous task processing (no separate Celery worker needed)
USE_SYNC_TASKS=true

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-latest

# Vector Database (ChromaDB)
CHROMA_PERSIST_DIRECTORY=/app/chroma_db
CHROMA_COLLECTION_NAME=documents

# Embedding Model (Open Source - HuggingFace)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cloudinary File Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS (set to your Vercel frontend URL after deploying)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Security
SECURE_SSL_REDIRECT=True

# Rate Limiting
DEFAULT_RATE_LIMIT=100/hour
PREMIUM_RATE_LIMIT=1000/hour

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10

# Gunicorn Workers (keep low for free tier 512MB RAM)
GUNICORN_WORKERS=2
